<+><template>\n  <div>\n    <canvas :id=\"chart_id\" width=\"800\" height=\"800\" aria-label=\"chart\" role=\"img\"></canvas>\n  </div>\n</template>\n\n<script>\nimport Chart from 'chart.js';\n\nexport default {\n  mounted() {\n    this.drawChart();\n  },\n  props: {\n    type: {\n      type: String,\n      default: 'line',\n    },\n    data: {\n      type: Object,\n      default: () => ({}),\n    },\n    partograph_options: {\n      type: Object,\n      default: () => ({}),\n    },\n  },\n  data() {\n    return {\n      chart_id: `chart-id-${Math.random().toString(36).substr(2, 9)}`,\n    };\n  },\n  methods: {\n    drawChart() {\n      const ctx = document.getElementById(this.chart_id);\n      const dataLabels = this.data.labels;\n      const dataValues = this.data.datasets[0].data;\n\n      // Find the index of the first non-empty label\n      let startIndex = 0;\n      while (startIndex < dataLabels.length && !dataLabels[startIndex]) {\n        startIndex++;\n      }\n\n      const firstTimestamp = new Date(dataLabels[startIndex]);\n      const startHour = firstTimestamp.getHours();\n\n      const xAxesTicks = {\n        ...this.partograph_options.scales?.xAxes?.[0]?.ticks,\n        min: startHour,\n        max: 24, // Assuming the x-axis has 24 hour slots\n        stepSize: 1,\n        callback: (value) => {\n          return `${value}:00`; // Format ticks as hours\n        },\n      };\n\n      new Chart(ctx, {\n        type: this.type,\n        data: this.data,\n        options: {\n          ...this.partograph_options,\n          scales: {\n            ...this.partograph_options.scales,\n            yAxes: [{\n              ...this.partograph_options.scales?.yAxes?.[0],\n              ticks: {\n                ...this.partograph_options.scales?.yAxes?.[0]?.ticks,\n                beginAtZero: false,\n                min: 60,\n                max: 180,\n                stepSize: 10,\n              },\n            }],\n            xAxes: [{\n              ...this.partograph_options.scales?.xAxes?.[0],\n              ticks: xAxesTicks,\n              gridLines: {\n                display: true, // Display grid lines\n                color: 'rgba(0, 0, 0, 0.1)', // Set grid line color\n              },\n            }],\n          },\n          tooltips: {\n            callbacks: {\n              title: (tooltipItems, data) => {\n                const index = tooltipItems[0].index;\n                const timestamp = dataLabels[index];\n                return `Time: ${timestamp}`;\n              },\n              label: (tooltipItem, data) => {\n                return `${data.datasets[tooltipItem.datasetIndex].label}: ${tooltipItem.yLabel}`;\n              },\n            },\n          },\n        },\n      });\n    },\n  },\n};\n</script>\n
