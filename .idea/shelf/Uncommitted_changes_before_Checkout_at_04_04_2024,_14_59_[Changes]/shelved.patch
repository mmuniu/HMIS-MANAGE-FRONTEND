                $result = $response;\n\n                    Log::info('Sales Line');\n                    Log::info($result);\n\n                    $line_count++;\n                    // return  $singleQuotedData;\n                }\n\n\n                $this->createMicrosoftDynamicsReceipt($invoice,$payment);\n                return \"done\";\n\n\n            } else {\n                return false;\n            }\n\n        } catch (\\Exception $e) {\n            // Handle exceptions here\n            Log::error('An error occurred: ' . $e->getMessage());\n            return false; // Or handle the error as required\n        }\n\n\n    }\n\n\n    public function createMicrosoftDynamicsReceipt($invoice,$payment)\n    {\n\n        Log::info($payment);\n        $invoice = explode(\",\",$invoice);\n\n        Log::info($invoice);\n        $username = env('MICROSOFT_DYNAMICS_USERNAME');\n        $password =  env('MICROSOFT_DYNAMICS_PASSWORD');\n\n        // Base64 encode the username and password\n        $credentials = \"$username:$password\";\n\n        $receiptEndpoint =   'http://34.195.156.236:7048/BC230/api/Nexus/PayGate/v1.0/companies('.$company.')/payments';\n\n        $receiptData = [\n            \"transactionCode\"=> $payment['receipt'],\n            \"transactionDate\"=> date('Y-m-d\\TH:i:s\\Z'),\n            \"bankAccountNo\"=> \"\",\n            \"payerID\"=> \"\",\n            \"amount\"=> $payment['amount'],\n            \"description\"=> \"\",\n            \"paymentMode\"=> \"\",\n            \"payerNames\"=> \"\",\n            \"processedDateTime\"=>  date('Y-m-d\\TH:i:s\\Z'),\n            \"status\"=> \"Pending\",\n            \"sourceDocumentNo\"=> $payment['receipt'],\n            \"sourceDocumentType\"=> \"Invoices\",\n            \"customerNo\"=> \"\",\n            \"accountNo\"=> \"\",\n            \"providerID\"=> \"\",\n            \"promiseToPay\"=> false,\n            \"isCreditPayment\"=> false,\n            \"creditReferenceNo\"=> \"\",\n            \"isOverpaymentApplication\"=> false,\n            \"overpaymentApplicationNo\"=> \"\",\n            \"currencyCode\"=> \"\",\n            \"serviceAmount\"=> 0,\n            \"base64Attachment\"=> \"\"\n        ];\n\n        $jsonData = '{';\n        foreach ($receiptData as $key => $value)\n            if (is_int($value) && $key!=\"documentNo\" && $key!=\"lineNo\") {\n                // If value is integer, no quotes needed\n                $jsonData .= \"\\\"$key\\\":$value,\";\n            } else\n            {\n                $jsonData .= \"\\\"$key\\\":\\\"\" . (is_bool($value) ? ($value ? 'true' : 'false') : $value) . \"\\\",\";\n            }\n\n        $jsonData = rtrim($jsonData, ',') . '}';\n        $singleReceiptLine = $jsonData;\n\n\n        $curl = curl_init();\n        curl_setopt_array($curl, array(\n            CURLOPT_URL => $receiptEndpoint ,\n            CURLOPT_RETURNTRANSFER => true,\n            CURLOPT_ENCODING => '',\n            CURLOPT_MAXREDIRS => 10,\n            CURLOPT_TIMEOUT => 0,\n            CURLOPT_FOLLOWLOCATION => true,\n            CURLOPT_HTTP_VERSION => CURL_HTTP_VERSION_1_1,\n            CURLOPT_HTTPAUTH => CURLAUTH_NTLM,\n            CURLOPT_USERPWD=> $credentials,\n            CURLOPT_CUSTOMREQUEST => 'POST',\n            CURLOPT_POSTFIELDS =>$singleReceiptLine,\n            CURLOPT_HTTPHEADER => array(\n                'Content-Type: application/json'\n            ),\n        ));\n\n        Log::info($receiptData);\n\n        $response = curl_exec($curl);\n        $status_code = curl_getinfo($curl, CURLINFO_HTTP_CODE); // Get the HTTP status code\n        curl_close($curl);\n        // $result = json_decode($response['invoice_id'], true);\n        $result = $response;\n\n\n        Log::info('Receipt Payment');\n        Log::info($result);\n\n\n    }\n\n    public function prepareBill()\n    {\n        return DB::transaction(function () {\n            $existing_bill = $this->checkUnpaidBill((int)request('patient'));\n\n            if($existing_bill) {\n                $prepared_bill = $existing_bill;\n            } else {\n                $prepared_bill = PreparedBill::create([\n                    'patient_id' => (int)request('patient'),\n                    'mode' => request('mode'),\n                    'total_amount' => (int)request('total_amount'),\n                    'amount_to_pay' => (int)request('amount_to_pay'),\n                    'status' => null\n                ]);\n            }\n\n            foreach(request('bills') as $bill) {\n                $data = array_merge(['prepared_bill_id' => $prepared_bill->id], $bill);\n\n                PreparedBillDetails::updateOrCreate($bill, $data);\n            }\n\n            return response()->json([\n                \"message\" => \"Bill raised successfully\",\n                \"alert\" => \"success\",\n                \"key\" => $prepared_bill->unique_id\n            ]);\n        });\n    }\n\n    public function checkUnpaidBill ($patient_id)\n    {\n        return PreparedBill::where('patient_id', $patient_id)\n            ->whereNull('status')->latest()->first();\n    }\n\n    /*\n     * fetch prepared bill by key\n     * */\n    public function fetchPreparedBill ()\n    {\n        $bill = PreparedBill::where('unique_id', request('bill_id'))->firstOrFail();\n\n        return new PreparedBillResource($bill);\n    }\n\n    /*\n     * settle the previously raised bill\n     * */\n    public function settleRaisedBill ()\n    {\n        return DB::transaction(function () {\n            $data = request('data');\n\n            $bill = PreparedBill::where('unique_id', $data['key'])->firstOrFail();\n\n            if($data['paid_amount'] >= $data['total_amount']) { // means whole amount paid\n                $bill->update([\n                    'status' => \"completed\"\n                ]);\n\n                return $this->recordPayment($bill->patient->id, true);\n            } else {\n                $bill->update([\n                    'status' => \"partially_paid\"\n                ]);\n\n                return $this->recordPayment($bill->patient->id, false);\n            }\n        });\n    }\n\n    /*\n     * get patient account balance\n     * */\n    public  function getPatientAccountBalance ($patient)\n    {\n        $account = $patient->account;\n\n        return $account ?  $account->balance : 0;\n    }\n\n    /*\n     * return visit bills : currently in use when splitting bills\n     * */\n    public function fetchVisitBills ($visit)\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = (new PatientVisitBill($visit))->getData();\n\n        return $data;\n    }\n}\n
