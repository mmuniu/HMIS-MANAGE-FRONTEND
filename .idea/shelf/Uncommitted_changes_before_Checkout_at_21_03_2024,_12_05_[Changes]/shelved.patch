+    /*
+     * transform movements
+     *
+     * */
+    public function transformMovements($movements)
+    {
+        $data = [
+            "markers" => [],
+            "lines" => [],
+        ];
+
+        $counter = 0;
+
+        foreach($movements as $index => $movement) {
+
+            array_push($data['markers'], [
+                "id" => $movement->id,
+                "position" => [
+                    "lat" => (int) $movement->lat,
+                    "lng" => (int) $movement->long
+                ]
+            ]);
+
+            if($index + 1 < count($movements)) {
+                $next = PatientMovement::findOrFail($movement->id + 1);
 
+                array_push($data["lines"], [
+                    "id" => $counter,
+                    "path" => [
+                        ["lat" => (int) $movement->lat, "lng" => (int) $movement->long],
+                        ["lat" => (int) $next->lat, "lng" => (int) $next->long],
+                    ]
+                ]);
+            }
+
+            $counter++;
+        }
+
+        if($counter > 0) {
+            $data["center"] = $data['markers'][ceil($counter / 2) - 1]["position"];
+        }
+
+        return $data;
+    }
