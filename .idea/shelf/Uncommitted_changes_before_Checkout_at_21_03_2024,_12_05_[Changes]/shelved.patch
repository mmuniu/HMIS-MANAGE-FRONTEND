+    /*
+     * Check if a patient already exists. Useful during registering a new patient
+     * We check the first_name, middle-name, last_name and id_number to validate the patient
+     * If you are a future developer thinking - "Hmmmm! What if there exists a
+     * parent who named their kid the exact same way they were named themselves!
+     * We would like to tell you that in that situation then feel free to modify this. We failed
+     * to get proper validation in such scenarios and simply ignored it. We imagined
+     * that in future tech will be better and developers will be wiser so you should be able to figure it out. :)"
+     */
+    public function patientExists($patient)
+    {
+        $exists = false;
+
+        $middleName = isset($patient["middle_name"]) ?? $patient["middle_name"];
+
+        $fullName = $patient["first_name"] . " " . $middleName . " " . $patient["last_name"];
+
+        $idNumber = $patient["id_no"];
+
+        Patients::chunk(250, function ($patients) use($fullName, $idNumber, &$exists){
+            foreach ($patients as $patient)
+            {
+                if(strcasecmp($patient->fullName, trim($fullName)) == 0 and strcasecmp(trim($patient->id_no), trim($idNumber)) == 0)
+                {
+                    $exists = true;
+
+                    return false;
+                }
+            }
+        });
+
+        return $exists;
+    }
