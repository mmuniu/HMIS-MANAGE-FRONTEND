+    /*
+     * upload patient image
+     * */
+    public function uploadPatientImage($patient_id)
+    {
+        request()->validate([
+            'image' => 'file|image|mimes:jpeg,png,PNG,JPEG'
+        ]);
+
+        $patient = Patients::findOrFail($patient_id);
+
+        $file = request()->file("image");
+
+        if ($file) {
+            if($patient->image) {
+                Storage::disk('public')->delete($patient->image);
+            }
+
+            $file_name = "patient_images/" . 'image_' . $patient_id . '.' . $file->extension();
+
+            Storage::disk('public')->put( $file_name, file_get_contents($file));
+
+            $patient->image = $file_name;
+
+            $patient->save();
+        }
+
+        return response()->json([
+            'message' => 'Successfully uploaded',
+            'alert' => 'success'
+        ]);
+    }
