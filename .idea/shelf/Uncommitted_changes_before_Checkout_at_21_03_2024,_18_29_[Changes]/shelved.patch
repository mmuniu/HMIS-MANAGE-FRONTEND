<+><?php\n/**\n * Created by PhpStorm\n * User: jjoek\n * Date: 2020-01-10\n * Time: 21:15\n */\n\nnamespace Ignite\\Finance\\Library;\n\n\nuse Ignite\\Reception\\Transformers\\PatientResource;\nuse Ignite\\Theatre\\Entities\\TheatreOperation;\nuse Ignite\\Theatre\\Library\\Evaluation\\TheatreOperations\\Charges;\n\nclass PatientVisitBill\n{\n    protected $visit;\n\n    protected $total;\n\n    public function __construct($visit)\n    {\n        $this->visit = $visit;\n    }\n\n    /*\n     * $visit -> visit model\n     * */\n    public function getData ()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = array_merge(\n            $this->getInvestigations(),\n            $this->getPrescriptions(),\n            $this->getCopayments(),\n            request()->has('split_bill') && request('split_bill') ? [] : $this->getChangedToCash(),\n            $this->getConsumables(),\n            $this->getWardCharges(),\n            $this->getOtherInpatientCharges(),\n            $this->getTheatreOperationRoomCharges(),\n            // $this->getClinicianCharges(),\n            $this->getRebates()\n        );\n\n        return [\n            'patient' => new PatientResource($this->visit->patients),\n            'data' => $data,\n        ];\n    }\n\n    /*\n     * get ward charges in cases where the this was an inpatient case\n     * */\n    public function getWardCharges ()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        $query = $this->visit->wards()->whereNull('is_interim'); // avoid NULL\n\n        $visit_wards = $query->whereNull('moved_from_chargesheet')->get();\n\n        if($visit_wards->isNotEmpty()) {\n            $days_admitted  = $this->visit->admission->days_admitted;\n\n            foreach($visit_wards as $ward_charge) {\n\n                $ward = $ward_charge->ward;\n\n                $quantity = $ward_charge->changes_track ? $ward_charge->quantity : $days_admitted;\n\n                $amount = $quantity * $ward_charge->price;\n\n                if(!$ward_charge->split_bill_id && !$ward_charge->moved_from_chargesheet) {\n                    array_push($data, [\n                        \"item_id\" => $ward_charge->id,\n                        \"name\" => $ward->name,\n                        \"type\" => \"Ward charge\",\n                        \"quantity\" => $quantity,\n                        \"price\" => (int)$ward_charge->price,\n                        \"visit\" => (int)$ward_charge->visit_id,\n                        \"amount\" => (float) $amount,\n                        \"paid\" => null,\n                        \"service_type\" => 'ward'\n                    ]);\n                }\n            }\n        }\n\n        return $data;\n    }\n\n    /*\n     * get other inpatient charges\n     * */\n    public function getOtherInpatientCharges ()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        $query = $this->visit->inpatientCharges()->whereNull('is_interim')->where('cancelled', 0);\n\n        $visitCharges = $query->whereNull('moved_from_chargesheet')->get();\n\n        if($visitCharges->isNotEmpty()) {\n            $days_admitted  = $this->visit->admission->days_admitted;\n\n            foreach($visitCharges as $charge) {\n\n                if($charge->charge->type == 'recurring' || $charge->chages_track) {\n                    $quantity = $charge->changes_track != null ? $charge->quantity : $days_admitted;\n                } else {\n                    $quantity = $charge->quantity;\n                }\n\n                $amount = $quantity * $charge->price;\n\n                if((!$charge->cancelled && !$charge->split_bill_id && !$charge->moved_from_chargesheet)) {\n                    array_push($data, [\n                        \"item_id\" => $charge->id,\n                        \"name\" => @$charge->charge->name,\n                        \"type\" => \"Admission + Daily charges\",\n                        \"quantity\" => $quantity,\n                        \"price\" => (int)$charge->price,\n                        \"visit\" => (int)$charge->visit_id,\n                        \"amount\" => (float) $amount,\n                        \"paid\" => null,\n                        \"service_type\" => 'admission_charges'\n                    ]);\n                }\n            }\n        }\n\n        return $data;\n    }\n\n    /*\n     * prepare investigation bills\n     * */\n    private function getInvestigations()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        $visit_investigations = $this->visit->investigations()\n            ->whereNull('moved_from_chargesheet')\n            ->whereNull('is_interim')\n            ->get();\n\n        foreach ($visit_investigations as $bill) {\n            if (!$bill->payment_details_id  && !$bill->moved_from_chargesheet) {\n                array_push($data, [\n                    \"item_id\" => $bill->id,\n                    \"name\" => @$bill->procedures->name,\n                    \"type\" => \"investigation\",\n                    \"quantity\" => $bill->quantity,\n                    \"price\" => (int)$bill->price,\n                    \"visit\" => (int)$bill->visit,\n                    \"discount\" => $bill->discount,\n                    \"amount\" => (float)$bill->amount,\n                    \"paid\" => null,\n                    \"service_type\" => 'investigation'\n                ]);\n\n                $this->total += $bill->amount;\n            }\n        }\n\n        return $data;\n    }\n\n    /*\n     * prepare prescription bills\n     * */\n    private function getPrescriptions()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        $visit_prescriptions = $this->visit->prescriptions()\n            ->whereNull('moved_from_chargesheet')\n            ->whereNull('is_interim')\n            ->where('canceled', 0)\n            ->get();\n\n        foreach ($visit_prescriptions as $bill) {\n            if (!$bill->payment_details_id) {\n                $price = $bill->price;\n\n                $quantity = @$bill->quantity;\n\n                $amount = ((double) $price * (double) $quantity);\n\n                array_push($data, [\n                    \"item_id\" => $bill->id,\n                    \"name\" => @$bill->drug_name,\n                    \"type\" => \"prescription\",\n                    \"quantity\" => $quantity,\n                    \"price\" => (int) $price,\n                    \"visit\" => (int)@$bill->visit,\n                    \"discount\" => 0,\n                    \"amount\" => (float) $amount,\n                    \"paid\" => null,\n                    \"service_type\" => 'prescription'\n                ]);\n\n                $this->total += $amount;\n            }\n        }\n\n        return $data;\n    }\n\n    /*\n     * get consumables used\n     * */\n    public function getConsumables ()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        foreach ($this->visit->consumables()->whereNull('moved_from_chargesheet')\n                     ->whereNull('is_interim')\n                     ->get() as $bill) {\n\n            if (!$bill->stopped && $bill->bill && !$bill->invoice_id && !$bill->split_bill_id && !$bill->moved_from_chargesheet  || // outpatient check\n                $this->visit->admission\n            ) {\n                array_push($data, [\n                    \"item_id\" => @$bill->id,\n                    \"name\" => @$bill->product->name,\n                    \"type\" => \"consumable\",\n                    \"quantity\" => @$bill->quantity,\n                    \"price\" => (int) @$bill->price,\n                    \"amount\" => (float) @$bill->amount,\n                    \"paid\" => null,\n                    \"visit\" => (int)@$bill->visit_id,\n                    \"service_type\" => 'consumable'\n                ]);\n            }\n        }\n\n        return $data;\n    }\n\n    /*\n     * copayments\n     * */\n    private function getCopayments ()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        if($this->visit->payment_mode === 'insurance') {\n            if($this->visit->copay->isNotEmpty())  {\n\n                $copayments = $this->visit->copay;\n\n                foreach($copayments as $bill) {\n                    if(!@$bill->payment_id) {\n                        array_push($data, [\n                            \"item_id\" => @$bill->id,\n                            \"name\" => 'Insurance copay',\n                            \"type\" => \"copay\",\n                            \"quantity\" => 1,\n                            \"price\" => $bill->amount,\n                            \"visit\" => $this->visit->id,\n                            \"amount\" => (float) @$bill->amount,\n                            \"paid\" => null\n                        ]);\n                    }\n                }\n            }\n        }\n\n        return $data;\n    }\n\n    /*\n     * fetch rebates\n     * */\n    private function getRebates()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $rebates = $this->visit->inpatientRebates()->with('rebate', 'user')->get();\n\n        if($rebates->isNotEmpty()) {\n            $data = [];\n\n            foreach($rebates as $rebate) {\n                array_push($data, [\n                    \"item_id\" => @$rebate->id,\n                    \"name\" => \"NHIF Rebate\",\n                    \"type\" => \"rebate\",\n                    \"quantity\" => 1,\n                    \"price\" => @$rebate->amount,\n                    \"visit\" => $this->visit->id,\n                    \"amount\" => (float) @$rebate->amount,\n                    \"paid\" => null,\n                ]);\n            }\n\n            return $data;\n        } else {\n            return [];\n        }\n    }\n\n    /*\n     * get what is changed to cash from insurance (int)@$bill->payment->price\n     * */\n    private function getChangedToCash ()\n    {\n        ini_set('max_execution_time', 0);\n\n        set_time_limit(0);\n\n        $data = [];\n\n        if($this->visit->payment_mode === 'insurance')\n        {\n            if(!empty($this->visit->to_cash)) {\n                foreach ($this->visit->to_cash as $bill) {\n                    if($bill->prescription_id) {\n                        if (!$bill->payment_details_id and !$bill->prescription->stopped && !$bill->invoiced ) {\n                            array_push($data, [\n                                \"item_id\" => $bill->prescription_id,\n                                \"name\" => @$bill->prescription->drugs->name,\n                                \"type\" => \"changed to cash\",\n                                \"quantity\" => $bill->prescription->payment->quantity,\n                                \"price\" =>$bill->prescription->payment->price,\n                                \"visit\" => (int)@$bill->visit_id,\n                                \"amount\" =>$bill->prescription->payment->amount,\n                                \"paid\" => null,\n                                \"service_type\" =>'prescription'\n                            ]);\n\n                        }\n                    } else if($bill->procedure_id) {\n                        if (!$bill->investigation->is_paid && !$bill->invoiced ) {\n                            array_push($data, [\n                                \"item_id\" => $bill->procedure_id,\n                                \"name\" => @$bill->investigation->procedures->name,\n                                \"type\" => \"changed to cash\",\n                                \"quantity\" => $bill->investigation->quantity,\n                                \"price\" => $bill->investigation->price,\n                                \"visit\" => (int)@$bill->visit_id,\n                                \"amount\" => $bill->investigation->amount,\n                                \"paid\" => null,\n                                \"service_type\" => 'investigation'\n                            ]);\n\n                        }\n                    }\n                }\n            }\n        }\n\n        return $data;\n    }\n\n\n    /**\n     * @return array\n     */\n    public function getTheatreOperationRoomCharges()\n    {\n        $theatre_operation = TheatreOperation::where('visit_id', $this->visit->id)->first();\n\n        if($theatre_operation) {\n            $fee = (new Charges($theatre_operation))->theatreFees();\n            \\Log::info($fee);\n            return [\n                [\n                    // 'item_id' => $fee['id'],\n                    'name' => $fee['name'],\n                    'type' => 'Theatre fee',\n                    'quantity' => $fee['minutes'],\n                    // 'price' => $fee['rate'],\n                    'visit' => $this->visit->id,\n                    'amount' => $fee['total'],\n                    'paid' => null,\n                    'service_type' => 'theatre_fee',\n                ]\n            ];\n        } else {\n            return [];\n        }\n    }\n\n    /**\n     * @return array|\\Illuminate\\Support\\Collection\n     */\n    public function getClinicianCharges()\n    {\n        $theatre_operation = TheatreOperation::where('visit_id', $this->visit->id)->first();\n        \\Log::info($theatre_operation);\n        if($theatre_operation) {\n            $fees = (new Charges($theatre_operation))->medicFees($theatre_operation);\n\n            return collect($fees)->transform(function ($fee) {\n                return [\n                    'item_id' => $fee['id'],\n                    'name' => $fee['name'],\n                    'type' => 'Theatre clinician fee',\n                    'quantity' => $fee['time'],\n                    'price' => $fee['rate'],\n                    'visit' => $this->visit->id,\n                    'amount' => $fee['total'],\n                    'paid' => null,\n                    'service_type' => 'theatre_clinician_fee',\n                ];\n            })->toArray();\n        } else {\n            return [];\n        }\n    }\n}\n
