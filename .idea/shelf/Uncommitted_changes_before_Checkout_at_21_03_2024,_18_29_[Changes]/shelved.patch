request('data') : request()->all();\n\n            $internal = array_has($data, 'internal_payment') ? true : false;\n\n            $patient_id =  $internal ? $data['patient_id'] : $patient;\n\n            if(request('forInpatient'))\n            {\n                $paymentMode = null;\n                $paymentModeData = [];\n\n                $patient = Patients::findOrFail($patient_id);\n\n                foreach($data as $key => $value)\n                {\n                    if(in_array($key, mconfig('finance.config.cash_payment_methods')) and ! is_null($value['amount']))\n                    {\n                        $paymentMode = $key;\n                        $paymentModeData = $value;\n                    }\n                }\n\n                if($paymentMode)\n                {\n                    $IPDData = array_merge($data, [\n                        'payment_mode' => $paymentMode,\n                        'payment_mode_data' => $paymentModeData,\n                        'amount' => $paymentModeData['amount'],\n                        \"receipt\" => finance_generate_receipt_no(),\n                        'receipt_prefix' => m_setting('finance.receipt_prefix') ? m_setting('finance.receipt_prefix') : 'RE',\n                    ]);\n\n                    $deposit = (new AccountDeposits($patient))->recordDeposit($IPDData);\n                    $patientAccount = (new AccountDeposits($patient))->updateAccount($deposit);\n                    $payment = $deposit; // for return purposes\n                }\n\n                /*\n                 * process save insurance max amount if stated\n                 */\n                if(!empty(request('insurance')['amount'])) {\n                    $visit = Visit::find(request('visitId'));\n\n                    $visit->insuranceMaximumAmount()->create([\n                        'scheme_id' => request('insurance')['scheme'],\n                        'maximum_amount' => request('insurance')['amount'],\n                    ]);\n                }\n\n            }\n            else {\n                $from_account = ($data['patientAccount'] && !empty($data['patientAccount']['amount'])) ? $data['patientAccount']['amount'] : 0;\n\n                $payment = EvaluationPayments::create([\n                    \"receipt\" => finance_generate_receipt_no(),\n                    'receipt_prefix' => m_setting('finance.receipt_prefix') ? m_setting('finance.receipt_prefix') : 'RE',\n                    \"patient\" => $patient_id,\n                    \"user\" => doe()->id,\n                    \"amount\" => $data['paid_amount'],\n                    \"total_cash_payment\" => ($data['paid_amount'] - $from_account),\n                    \"discount\" => array_has($data, 'percentage_discount') ? $data['percentage_discount'] : null,\n                    \"discount_reason\" => $data['reason_for_discount'],\n                    \"total_amount_was\" => $data['total_amount'],\n                    \"cash_amount\" => ($data['cash'] && !empty($data['cash']['amount'])) ? $data['cash']['amount'] : 0,\n                    \"card_amount\" => ($data['card'] && !empty($data['card']['amount'])) ? $data['card']['amount'] : 0,\n                    \"mpesa_amount\" => ($data['mpesa'] && !empty($data['mpesa']['amount'])) ? $data['mpesa']['amount'] : 0,\n                    \"cheque_amount\" => ($data['cheque'] && !empty($data['cheque']['amount'])) ? $data['cheque']['amount'] : 0,\n                    \"patientAccount_amount\" => $from_account,\n                ]);\n\n\n                $items = request('selected');\n\n                Log::info($items);\n\n                $visit = request('visitId');\n\n\n\n                $this->createMicrosoftDynamicsData($payment,$items,$visit);\n\n                $details = $internal ? $data['selected'] : $data['details'];\n\n                $this->processPaymentDetails($payment, $details, $full_pay);\n\n                $this->savePaymentModesUsed($data, $payment, $internal);\n\n            }\n\n            if ($data['wallet'] && $data['wallet']['wallet_account_amount'] ) {\n\n                //First check if the patient has transactions which were not marked as complete\n                $finsprint_pending_transactions = FinsprintTransaction::where('status','pending')->get();\n\n\n                if($finsprint_pending_transactions->isNotEmpty()){\n\n                    foreach ($finsprint_pending_transactions as $finsprint_pending_transaction){\n\n                        if ($finsprint_pending_transaction->account_number === $data['wallet']['wallet_number']) {\n                            $post_data = [\n                                'transaction_id' => isset($finsprint_pending_transaction->transaction_id) ? $finsprint_pending_transaction->transaction_id : null,\n                                'action' => \"process\",\n                                'remarks' => 'Process completion',\n                            ];\n\n                            $this->finsprint->initiateCompleteTransaction($post_data);\n                        } else {\n                            // Log a message or perform any other action if account_number doesn't match\n                        }\n\n                    }\n\n                }else{\n                    $post_data = [\n                        \"is_internal\" => false,\n                        \"debit_account_number\" =>$data['wallet']['wallet_number'],\n                        \"credit_account_number\" => \"1115510000203\", // constant\n                        \"transaction_type\" => \"hmis_payment\",\n                        \"currency\" => \"KES\",\n                        \"amount\" => $data['wallet']['wallet_account_amount'],\n                        \"reference_id\" => finance_generate_receipt_no(),\n                        \"remarks\" => \"IP Payment\",\n                        \"result_url\" => \"https://kakamegacounty.collabmed.net/finance/api/finsprint-callback\",\n                        \"aut