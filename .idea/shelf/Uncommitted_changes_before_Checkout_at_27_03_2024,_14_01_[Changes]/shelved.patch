<+><?php\n\nnamespace Ignite\\Finance\\Http\\Controllers;\n\nuse Carbon\\Carbon;\nuse Ignite\\Core\\Http\\Controllers\\AdminBaseController;\nuse Ignite\\Core\\Library\\PrintManager;\nuse Ignite\\Evaluation\\Entities\\Dispensing;\nuse Ignite\\Evaluation\\Entities\\Investigations;\nuse Ignite\\Evaluation\\Entities\\Prescriptions;\nuse Ignite\\Evaluation\\Entities\\Visit;\nuse Ignite\\Evaluation\\Events\\SaleRequested;\nuse Ignite\\Finance\\Entities\\Dispatch;\nuse Ignite\\Finance\\Entities\\DispatchDetails;\nuse Ignite\\Finance\\Entities\\EvaluationPayments;\nuse Ignite\\Finance\\Entities\\FinanceEvaluationInsurancePayments;\nuse Ignite\\Finance\\Entities\\Invoice;\nuse Ignite\\Finance\\Entities\\JambopayPayment;\nuse Ignite\\Finance\\Entities\\PatientTransaction;\nuse Ignite\\Finance\\Entities\\PaymentManifest;\nuse Ignite\\Finance\\Entities\\SplitInsurance;\nuse Ignite\\Finance\\Http\\Requests\\PaymentsRequest;\nuse Ignite\\Finance\\Repositories\\EvaluationRepository;\nuse Ignite\\Finance\\Repositories\\Jambo;\nuse Ignite\\Inpatient\\Entities\\ChargeSheet;\nuse Ignite\\Inventory\\Entities\\InventoryBatchProductSales;\nuse Ignite\\Inventory\\Entities\\StorePrescription;\nuse Ignite\\Inventory\\Entities\\StoreProduct;\nuse Ignite\\Reception\\Entities\\Patients;\nuse Ignite\\Settings\\Entities\\Insurance;\nuse Illuminate\\Database\\Eloquent\\Builder;\nuse Illuminate\\Http\\Request;\n\nclass EvaluationController extends AdminBaseController\n{\n\n    /**\n     * @var EvaluationRepository\n     */\n    protected $evaluationRepository;\n\n    /**\n     * EvaluationController constructor.\n     * @param EvaluationRepository $evaluationRepository\n     */\n    public function __construct(EvaluationRepository $evaluationRepository)\n    {\n        parent::__construct();\n        $this->evaluationRepository = $evaluationRepository;\n    }\n\n    public function sale_details(Request $request)\n    {\n        $this->data['sales'] = InventoryBatchProductSales::find($request->sale);\n        return view('finance::evaluation.sale_preview', ['data' => $this->data]);\n    }\n\n    public function printA4Receipt(Request $request)\n    {\n        $this->data['invoice_mode'] = $request->invoice;\n        $this->data['payment'] = $payment = EvaluationPayments::find($request->payment);\n        $this->data['disp'] = json_decode($payment->dispensing);\n        $this->data['a4'] = 1;\n        return view('finance::evaluation.print.receipt', ['data' => $this->data]);\n        // $pdf = \\PDF::loadView('finance::evaluation.print.receipt', ['data' => $this->data]);\n        // $pdf->setPaper('a4', 'Potrait');\n        //return @$pdf->stream('Bill' . $request->id . '.pdf');\n    }\n\n    public function printThermalReceipt(Request $request) // merge this thing later\n    {\n        $this->data['invoice_mode'] = $request->invoice;\n        $this->data['payment'] = $payment = EvaluationPayments::find($request->payment);\n        $this->data['disp'] = json_decode($payment->dispensing);\n\n        $print = (new PrintManager('thermal'))\n            ->setData($this->data)\n            ->setView('finance::evaluation.print.receipt')\n            ->setThermalHeightByInteger(900)\n            ->setPrintTitle('Bill' . $request->id);\n\n        return $print->print();\n    }\n\n    public function printNormalReceipt(Request $request)\n    {\n        $this->data['invoice_mode'] = $request->invoice;\n        //$this->data['sales'] = InventoryBatchProductSales::find($id);\n        $this->data['payment'] = $payment = EvaluationPayments::find($request->payment);\n        ///dd($this->data);\n        $min_height = 900;\n        /*\n          foreach ($this->data['pa']->goodies as $n) {\n          $min_height += 20;\n          } */\n\n        if (isset($payment->visits->investigations)) {\n            foreach ($payment->visits->investigations as $i) {\n                $min_height += 20;\n            }\n        }\n\n        if (isset($payment->visits->dispensing)) {\n            foreach ($payment->visits->dispensing as $item) {\n                foreach ($item->details as $item) {\n                    $min_height += 20;\n                }\n            }\n        }\n\n        if (isset($payment->visits->drug_purchases)) {\n            foreach ($payment->visits->drug_purchases as $item) {\n                foreach ($item->details as $item) {\n                    $min_height += 20;\n                }\n            }\n        }\n\n        if ($payment->sale > 0) {\n            foreach ($payment->sales->goodies as $item) {\n                $min_height += 20;\n            }\n        }\n\n        $this->data['disp'] = json_decode($payment->dispensing);\n\n        $print = (new PrintManager(request('paper_size')))\n            ->setData($this->data)\n            ->setView('finance::evaluation.print.receipt_t')\n            ->setThermalHeightByInteger($min_height)\n            ->setPrintTitle('Receipt ' . $request->payment);\n\n        return $print->print();\n    }\n\n\n    public function payPOS()\n    {\n        $this->data['sales'] = InventoryBatchProductSales::wherePaid(false)\n            ->doesntHave('removed_bills')\n            ->whereNull('insurance')\n            ->orderBy('created_at', 'desc')\n            ->paginate(core_paginate('xxl'));\n\n        return view('finance::pay_pos', ['data' => $this->data]);\n    }\n\n    public function pharmacy_dispense(Request $request)\n    {\n//        \\Log::info(\"pharmacy dispense\");\n        if(request('print')) {\n            return $this->printProcessedMeds();\n        } else {\n            $stack = [];\n\n            foreach(request()->all() as $key => $value) {\n                if(starts_with($key, 'prescribedQuantity')) {\n                    $prescription_id = substr($key, 18);\n\n                    array_push($stack, $prescription_id);\n                }\n            }\n            \\Log::info($stack);\n\n            foreach ($stack as $index) {\n\n                $prescription = Prescriptions::find($index);\n\n                $price = @$prescription->payment->price;\n                $new_quantity = (int)\\request('qty' . $index);\n                $prescribed_quantity = (int)\\request('prescribedQuantity' . $index);\n\n                $update = [\n                    'complete' => true,\n                    'quantity' => $new_quantity,\n                    'amount' => $price * $new_quantity,\n                ];\n                // Check if the checkbox for this prescription item is checked\n\n                // Check if the checkbox for this prescription item is checked\n                $checkboxName = 'drugs-checkbox' . $index; // Adjust to match the actual name attribute\n                if ($request->has($checkboxName)) {\n                    $prescription->update(['processed' => true]);\n                }\n\n\n                if($prescription->visits->payment_mode === 'insurance') {\n\n                    if($prescribed_quantity > $new_quantity) { // has balance\n\n                        $prescriptionArray = $prescription->toArray();\n                        unset($prescriptionArray['users']);\n                        unset($prescriptionArray['payment']);\n                        unset($prescriptionArray['visits']);\n                        unset($prescriptionArray['id']);\n                        unset($prescriptionArray['created_at']);\n                        unset($prescriptionArray['updated_at']);\n                        $prescriptionArray['user'] = doe()->id;\n                        $prescriptionArray['paid'] = 0;\n                        $prescriptionArray[\"is_a_split\"] = true;\n                        $prescriptionArray[\"is_a_split\"] = '';\n                        $prescriptionArray[\"split_details\"] = \"This is not the actual initial prescription but an adjustment by\" . doe()->full_name . \" for claims purposes\";\n\n                        $new_prescription =  Prescriptions::create($prescriptionArray);\n\n                        StorePrescription::create([\n                            'product_id' => $new_prescription->drug,\n                            'store_id' => $prescription->store->store_id,\n                            'store_product_id' => $prescription->store->store_product_id,\n                            'prescription_id' => $new_prescription->id,\n                            'quantity' => $new_prescription->quantity\n                        ]);\n\n                        $amount = $price * ($prescribed_quantity - $new_quantity);\n\n                        $new_prescription->payment()->create([\n                            'price' => $price,\n                            'amount' => $amount,\n                            'quantity' => ($prescribed_quantity - $new_quantity)\n                        ]);\n\n                        event(new SaleRequested(\n                            doe()->id,\n                            'prescription',\n                            $prescription->id,\n                            $price,\n                            $new_prescription->quantity,\n                            $amount,\n                            'Pharmacy',\n                            $new_prescription->drugs->name,\n                            $new_prescription->visit,\n                            get_clinic()->id\n                        ));\n                    }\n                }\n\n                $prescription->payment()->update($update);\n            }\n\n            if ($request->has('to_redirect')) {\n                // return redirect()->route('finance.evaluation.prepare.bill', [$request->to_redirect, 'visit' => request('visit')]);\n                return redirect()->route('finance.invoices.action', ['pending', 'bill', 'visit_id' => request('visit')]);\n            }\n\n            // receive cash payment now\n            // return redirect()->route('finance.evaluation.pay', $request->patient);\n            return redirect()->route('finance.cash.index', ['receive', 'patient_id' => $request->patient]);\n        }\n    }\n\n    /*\n    * print processed meds\n    * */\n    public function processAndCloseMeds (): \\Illuminate\\Http\\JsonResponse\n    {\n\n        $stack = [];\n\n        foreach(request()->all() as $key => $value) {\n            if(starts_with($key, 'prescribedQuantity')) {\n                $prescription_id = substr($key, 18);\n\n                array_push($stack, $prescription_id);\n            }\n        }\n\n        foreach ($stack as $index) {\n            $prescription = Prescriptions::find($index);\n\n            $price = @$prescription->payment->price;\n            $new_quantity = (int)\\request('qty' . $index);\n            $prescribed_quantity = (int)\\request('prescribedQuantity' . $index);\n\n            $update = [\n                'complete' => true,\n                'quantity' => $new_quantity,\n                'amount' => $price * $new_quantity,\n            ];\n\n            if($prescription->visits->payment_mode === 'insurance') {\n                if($prescribed_quantity > $new_quantity) { // has balance\n\n                    $prescriptionArray = $prescription->toArray();\n                    unset($prescriptionArray['users']);\n                    unset($prescriptionArray['payment']);\n                    unset($prescriptionArray['visits']);\n                    unset($prescriptionArray['id']);\n                    unset($prescriptionArray['created_at']);\n                    unset($prescriptionArray['updated_at']);\n                    $prescriptionArray['user'] = doe()->id;\n                    $prescriptionArray['paid'] = 0;\n                    $prescriptionArray[\"is_a_split\"] = true;\n                    $prescriptionArray[\"is_a_split\"] = '';\n                    $prescriptionArray[\"split_details\"] = \"This is not the actual initial prescription but an adjustment by\" . doe()->full_name . \" for claims purposes\";\n\n                    $new_prescription =  Prescriptions::create($prescriptionArray);\n\n                    StorePrescription::create([\n                        'product_id' => $new_prescription->drug,\n                        'store_id' => $prescription->store->store_id,\n                        'store_product_id' => $prescription->store->store_product_id,\n                        'prescription_id' => $new_prescription->id,\n                        'quantity' => $new_prescription->quantity\n                    ]);\n\n                    $amount = $price * ($prescribed_quantity - $new_quantity);\n\n                    $new_prescription->payment()->create([\n                        'price' => $price,\n                        'amount' => $amount,\n                        'quantity' => ($prescribed_quantity - $new_quantity)\n                    ]);\n\n                    event(new SaleRequested(\n                        doe()->id,\n                        'prescription',\n                        $prescription->id,\n                        $price,\n                        $new_prescription->quantity,\n                        $amount,\n                        'Pharmacy',\n                        $new_prescription->drugs->name,\n                        $new_prescription->visit,\n                        get_clinic()->id\n                    ));\n                }\n            }\n\n            $prescription->payment()->update($update);\n        }\n\n        return response()->json([\n            'alert' => 'success',\n            'message' => 'Prescriptions added successfully!',\n        ], 200);\n    }\n    /*\n     * print processed meds\n     * */\n    public function printProcessedMeds ()\n    {\n        $stack = [];\n\n        foreach(request()->all() as $key => $value) {\n            if(starts_with($key, 'prescribedQuantity')) {\n                $prescription_id = substr($key, 18);\n\n                array_push($stack, $prescription_id);\n            }\n        }\n\n        $this->data['meds'] = collect();\n\n        foreach ($stack as $index) {\n            $prescription = Prescriptions::find($index);\n\n            $this->data['meds']->push([\n                'prescription' => $prescription,\n                'prescribed_quantity' => (int)\\request('prescribedQuantity' . $index),\n                'quantity' => (int)\\request('qty' . $index),\n            ]);\n        }\n\n        $min_height = 600;\n        $min_height += 20 * ($this->data['meds']->count());\n\n        $print = (new PrintManager('thermal'))\n            ->setData($this->data)\n            ->setView('finance::evaluation.print.processed_meds_thermal')\n            ->setThermalHeightByInteger($min_height)\n            ->setPrintTitle('Prescriptions note');\n\n        return $print->print();\n    }\n\n    /**\n     * Build an index of items dynamically\n     * @return array\n     */\n    private function _get_selected_stack()\n    {\n        $stack = [];\n        $input = \\request()->all();\n        foreach ($input as $key => $one) {\n            if (starts_with($key, 'item')) {\n                $stack[] = substr($key, 4);\n            }\n        }\n        return $stack;\n    }\n\n    public function payPharmacy(Request $request)\n    {\n        $patient = $request->patient;\n        $visit = $request->visit;\n\n        $this->data['patient'] = Patients::findOrFail($patient);\n        $this->data['visit'] = Visit::findOrFail($visit);\n\n        $this->data['drugs'] = Prescriptions::where('visit', $visit)->with('store')->whereHas('visits', function ($query) use ($patient) {\n            $query->wherePatient($patient);\n            $query->whereHas('prescriptions.payment', function ($builder) {\n                $builder->wherePaid(false);\n                $builder->whereInvoiced(false);\n            });\n        })->get();\n\n        foreach($this->data['drugs'] as $item)\n        {\n            if($item->store)\n            {\n                $item->storeProduct = StoreProduct::where('store_id', $item->store->store_id)->where('product_id', $item->store->product_id)->first();\n            }\n        }\n\n        if (isset($request->split)) {\n            $this->data['split'] = SplitInsurance::find($request->split);\n        }\n        if ($request->insurance) {\n            $this->data['to_redirect_insurance'] = $request->insurance;\n        }\n        $this->data['clinic_id']= get_clinic()->id;\n        return view('finance::evaluation.pay-pharmacy', ['data' => $this->data]);\n    }\n\n//End of patient invoicing\n    public function payment_details($id, $invoice = null)\n    {\n        $this->data['invoice_mode'] = $invoice;\n        $this->data['payment'] = $payment = EvaluationPayments::find($id);\n        $this->data['disp'] = json_decode($payment->dispensing);\n        $this->data['patient'] = Patients::find($payment->patient);\n        return view('finance::evaluation.details', ['data' => $this->data]);\n    }\n\n    public function sale_pay($sale = null)\n    {\n        if (!empty($sale)) {\n            $this->data['sales'] = InventoryBatchProductSales::find($sale);\n            return view('finance::evaluation.sale_pay', ['data' => $this->data]);\n        }\n\n        $this->data['sales'] = InventoryBatchProductSales::wherePaid(false)\n            ->get();\n\n        return view('finance::evaluation.payment_list', ['data' => $this->data]);\n    }\n\n\n    public function summary()\n    {\n        $this->data['all'] = EvaluationPayments::latest()->paginate(core_paginate('xxl'));\n        return view('finance::evaluation.summary', ['data' => $this->data]);\n    }\n\n    public function payInsBill(Request $request)\n    {\n        $this->data['visit'] = Visit::find($request->visit);\n        return view('finance::evaluation.pay_ins_bill', ['data' => $this->data]);\n    }\n\n    public function printInvoice(Request $request)\n    {\n        $this->data['bill'] = Invoice::find($request->id);\n\n        $print = (new PrintManager())\n            ->setData($this->data)\n            ->setView('finance::evaluation.print.invoice')\n            ->setPrintTitle('Bill' . $request->id);\n\n        return $print->print();\n    }\n\n    public function printReceipt(Request $request)\n    {\n        $payment = FinanceEvaluationInsurancePayments::find($request->id);\n        $pdf = \\PDF::loadView('finance::evaluation.print.rcpt', ['payment' => $payment]);\n        $pdf->setPaper('a4', 'potrait');\n        return @$pdf->stream('Bill' . $request->id . '.pdf');\n    }\n\n    public function printJamboReceipt(Request $request)\n    {\n        $payment = JambopayPayment::where('BillNumber', $request->bill)->first();\n        $height = 450;\n        $pdf = \\PDF::loadView('finance::evaluation.print.jp_bill', ['bill' => $payment]);\n        $customPaper = [0, 0, 300, $height];\n        $pdf->setPaper($customPaper);\n        return @$pdf->download('JP Bill ' . $request->bill . '.pdf');\n    }\n\n    public function billToCash(Request $request)\n    {\n        $visit = Visit::find($request->visit);\n        $visit->payment_mode = 'cash';\n        $visit->save();\n        flash(\"Bill changed to cash successfully\");\n        return back();\n    }\n\n    /**\n     * return the patient balance esp. when making a sale\n     * TODO// move this to patient accounts/profile section\n     * @param $patient_id\n     *\n     * @return int\n     */\n    public function getPatientBalance($patient_id)\n    {\n        return get_patient_balance($patient_id);\n    }\n\n}\n
